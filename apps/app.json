{
  "expo": {
    "name": "MonoPay",
    "slug": "monopay",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "mpay",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MonoPay to access your camera to scan payment QR codes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
