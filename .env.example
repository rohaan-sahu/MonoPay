# Sandbox SDK configuration for MonoPay (Expo runtime)
# IMPORTANT: EXPO_PUBLIC_ vars are bundled into the client app.
# Use throwaway/dev keys only for local testing.

# Solana / payment rails
EXPO_PUBLIC_MONOPAY_RPC_URL=https://api.devnet.solana.com
EXPO_PUBLIC_MONOPAY_SENDER_SECRET_KEY_JSON=[12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78,90,12,34,56,78]
EXPO_PUBLIC_MONOPAY_LAMPORTS_PER_USD=1000000
EXPO_PUBLIC_MONOPAY_DEFAULT_RECIPIENT_PUBLIC_KEY=
EXPO_PUBLIC_MONOPAY_HANDLE_DIRECTORY_JSON={"@merchant":"","@monopayuser":""}

# SPL mints (USDC/USDT)
EXPO_PUBLIC_MONOPAY_USDC_MINT=
EXPO_PUBLIC_MONOPAY_USDT_MINT=

# MagicBlock private rail (USDC testing)
EXPO_PUBLIC_MONOPAY_MAGICBLOCK_ENABLED=false
EXPO_PUBLIC_MONOPAY_MAGICBLOCK_API_BASE_URL=https://api.docs.magicblock.app
EXPO_PUBLIC_MONOPAY_MAGICBLOCK_DEPOSIT_BEFORE_TRANSFER=true
EXPO_PUBLIC_MONOPAY_MAGICBLOCK_INIT_RECIPIENT=true
EXPO_PUBLIC_MONOPAY_MWA_ENABLED=false

# `email_only` skips SMS provider requirements; `email_phone` enforces both channels.
EXPO_PUBLIC_MONOPAY_ACCOUNT_LINK_MODE=email_only

# Supabase Auth
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Metaplex Core
EXPO_PUBLIC_MONOPAY_IDCARD_METADATA_URI=https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/monopay-assets/metadata/monopay-id-card-v1.json
EXPO_PUBLIC_MONOPAY_IDCARD_OWNER_PUBLIC_KEY=
# Optional: avatar fallback used during auto-provisioning.
EXPO_PUBLIC_MONOPAY_PROFILE_AVATAR_FALLBACK_URL=https://api.dicebear.com/9.x/shapes/svg?seed=monopay
